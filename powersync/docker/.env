# postgres Database Config
PS_DATABASE_NAME=postgres
PS_DATABASE_PASSWORD=postgres
PS_DATABASE_PORT=54322
PS_DATABASE_USER=postgres
PS_DATA_SOURCE_URI=postgresql://${PS_DATABASE_USER}:${PS_DATABASE_PASSWORD}@host.docker.internal:${PS_DATABASE_PORT}/${PS_DATABASE_NAME}

# postgres Storage Config
PS_STORAGE_DATABASE=powersync_storage
PS_STORAGE_PASSWORD=changeme
PS_STORAGE_PORT=5433
PS_STORAGE_USER=postgres
PS_STORAGE_SOURCE_URI=postgresql://${PS_STORAGE_USER}:${PS_STORAGE_PASSWORD}@pg-storage:${PS_STORAGE_PORT}/${PS_STORAGE_DATABASE}

PS_JWKS_URI=http://host.docker.internal:54321/auth/v1/.well-known/jwks.json
